# SIGMON — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Replit DB, Neon, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ──────────────────────────────────────────────────────────────────────
# Long random string — generate one at https://randomkeygen.com
SESSION_SECRET=your-very-long-random-secret-key-here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# For Replit dev: your *.replit.dev domain
# For Vercel: your *.vercel.app domain
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:5173
